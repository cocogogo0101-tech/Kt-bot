# انسخ هذا الملف باسم .env وحط قيمك الحقيقية
# لا ترفع ملف .env الحقيقي لأي مكان (GitHub, ZIP للمشاركة, إلخ)

DISCORD_TOKEN=توكن_البوت_هنا
CLIENT_ID=آيدي_تطبيق_البوت_هنا

# يقدر تحط أكثر من سيرفر مفصولين بفاصلة (,) بدون مسافات
# مثال: ALLOWED_GUILD_IDS=111111111111111111,222222222222222222
ALLOWED_GUILD_IDS=آيدي_سيرفرك_المصرح_هنا

WEBHOOK_URL=رابط_الويب_هوك_حق_قناة_التنبيهات_هنا
STREAM_URL=https://twitch.tv/dark_kingz12

# منفذ سيرفر الـ Keep-Alive (اختياري، افتراضي 3000) — تستخدمه UptimeRobot
PORT=3000

# آيدي حسابك الشخصي (المالك) — بس أنت من يقدر يفعل الوضع السري
OWNER_ID=آيدي_حسابك_الديسكورد_هنا

# الكلمة السرية لتفعيل/تعطيل الوضع الرومانسي المخفي
# لازم تكتبها كرسالة كاملة لوحدها (مو أول كلمة برسالة، بل الرسالة بالكامل)
# لا تشاركها مع أحد — هذا المتغير سري
SECRET_TRIGGER=غيّرها_لكلمة_سرية_خاصة_فيك
